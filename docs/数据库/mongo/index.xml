&lt;h2&gt;常见问题与注意事项&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;常见问题与注意事项&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#%e5%b8%b8%e8%a7%81%e9%97%ae%e9%a2%98%e4%b8%8e%e6%b3%a8%e6%84%8f%e4%ba%8b%e9%a1%b9&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h2&gt;&lt;h3&gt;连接被拒绝&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;连接被拒绝&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#%e8%bf%9e%e6%8e%a5%e8%a2%ab%e6%8b%92%e7%bb%9d&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;ol&gt;
&lt;li&gt;检查端口是否被占用：&lt;/li&gt;
