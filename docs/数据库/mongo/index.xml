&lt;hr&gt;
&lt;h2&gt;常用管理命令&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;常用管理命令&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#%e5%b8%b8%e7%94%a8%e7%ae%a1%e7%90%86%e5%91%bd%e4%bb%a4&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h2&gt;&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;操作&lt;/th&gt;
          &lt;th&gt;命令&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;启动 MongoDB&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;docker compose up -d&lt;/code&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;停止 MongoDB&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;docker compose stop&lt;/code&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;重启 MongoDB&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;docker compose restart&lt;/code&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;查看状态&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;docker compose ps&lt;/code&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;查看日志&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;docker logs mongo -f --tail=100&lt;/code&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;进入容器&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;docker exec -it mongo /bin/bash&lt;/code&gt;&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;连接 MongoDB（容器内）&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;docker exec -it mongo mongosh -u root -p 123456&lt;/code&gt;&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h2&gt;导入与导出&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;导入与导出&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#%e5%af%bc%e5%85%a5%e4%b8%8e%e5%af%bc%e5%87%ba&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h2&gt;&lt;h3&gt;导入数据&lt;span class=&#34;hx:absolute hx:-mt-20&#34; id=&#34;导入数据&#34;&gt;&lt;/span&gt;
    &lt;a href=&#34;#%e5%af%bc%e5%85%a5%e6%95%b0%e6%8d%ae&#34; class=&#34;subheading-anchor&#34; aria-label=&#34;Permalink for this section&#34;&gt;&lt;/a&gt;&lt;/h3&gt;&lt;div class=&#34;hextra-code-block hx:relative hx:mt-6 hx:first:mt-0 hx:group/code&#34;&gt;

&lt;div&gt;&lt;div class=&#34;highlight&#34;&gt;&lt;pre tabindex=&#34;0&#34; class=&#34;chroma&#34;&gt;&lt;code class=&#34;language-bash&#34; data-lang=&#34;bash&#34;&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;c1&#34;&gt;# JSON 导入&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;docker &lt;span class=&#34;nb&#34;&gt;exec&lt;/span&gt; -i mongo mongoimport -u root -p &lt;span class=&#34;m&#34;&gt;123456&lt;/span&gt; --authenticationDatabase admin -d &lt;span class=&#34;nb&#34;&gt;test&lt;/span&gt; -c users &amp;lt; /path/to/users.json
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;&lt;span class=&#34;c1&#34;&gt;# BSON 导入&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span class=&#34;line&#34;&gt;&lt;span class=&#34;cl&#34;&gt;docker &lt;span class=&#34;nb&#34;&gt;exec&lt;/span&gt; -i mongo mongorestore -u root -p &lt;span class=&#34;m&#34;&gt;123456&lt;/span&gt; --authenticationDatabase admin --archive&lt;span class=&#34;o&#34;&gt;=&lt;/span&gt;/path/to/backup.archive&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&#34;hextra-code-copy-btn-container hx:opacity-0 hx:transition hx:group-hover/code:opacity-100 hx:flex hx:gap-1 hx:absolute hx:m-[11px] hx:right-0 hx:top-0&#34;&gt;
